{
  "messages": [
    {
      "content": "You are connected to a set of tools. Read the user's task and, if one of the available tools is appropriate, call exactly one tool to accomplish it. If no tool fits, answer in plain text.",
      "role": "system"
    },
    {
      "content": "<your task here>",
      "role": "user"
    }
  ],
  "model": "gpt-4o",
  "temperature": 1.0,
  "tool_choice": "auto",
  "tools": [
