        "parameters": {
          "properties": {
            "date": {
              "description": "ISO-8601 date.",
              "type": "string"
            },
            "party": {
              "properties": {
                "seating": {
                  "enum": [
                    "indoor",
                    "outdoor",
                    "bar"
                  ],
                  "type": "string"
                },
                "size": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "required": [
                "size"
              ],
              "type": "object"
            }
          },
          "required": [
            "party",
            "date"
          ],
          "type": "object"
        }
      },
      "type": "function"
    },
    {
